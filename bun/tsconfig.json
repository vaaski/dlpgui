{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"types": ["@types/bun"],
		"lib": ["ESNext"]
	},
	"include": [".", "../shared/**/*.d.ts"],
	"exclude": ["node_modules", "dist", "build", "../../package/dist"]
}
